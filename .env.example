# =============================================================================
# N8N-FounderStories Configuration Template
# =============================================================================
# Copy this file to .env and fill in your actual values
# NEVER commit .env with real credentials to version control
# =============================================================================

# =============================================================================
# Application Settings
# =============================================================================
APP_NAME=N8N-FounderStories
ENVIRONMENT=production
API_V1_PREFIX=/api/v1
LOG_LEVEL=INFO

# =============================================================================
# Server Configuration
# =============================================================================
HOST=0.0.0.0
PORT=8000
RELOAD=false

# =============================================================================
# Data Directory
# =============================================================================
N8N_DATA_DIR=

# =============================================================================
# LLM Provider (OpenRouter)
# =============================================================================
LLM_PROVIDER=openrouter
LLM_API_KEYS=your-openrouter-api-key-here
LLM_PREMIUM_MODELS=openai/gpt-4o-mini,google/gemini-2.5-flash,anthropic/claude-3.5-sonnet
LLM_FREE_MODELS=meta-llama/llama-3.2-3b-instruct:free,meta-llama/llama-3.3-70b-instruct:free
EMBEDDING_MODEL=openai/text-embedding-3-large
OPENROUTER_APP_TITLE=N8N-FounderStories
OPENROUTER_HTTP_REFERER=https://impulsq.de
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
LLM_TIMEOUT_S=60.0
LLM_MAX_RETRIES=2

# =============================================================================
# Module-Specific LLM Tier Assignments
# =============================================================================
PROMPT_TIER=LLM_PREMIUM_MODELS
SEARCH_PLAN_TIER=LLM_PREMIUM_MODELS
LINK_CLASSIFIER_TIER=LLM_PREMIUM_MODELS
BLOG_EXTRACTOR_TIER=LLM_PREMIUM_MODELS

# =============================================================================
# External API Integrations
# =============================================================================
HUNTER_API_KEY=your-hunter-api-key-here
HUNTER_BASE_URL=https://api.hunter.io/v2
GOOGLE_MAPS_API_KEY=your-google-maps-api-key-here
GOOGLE_PLACES_BASE_URL=https://maps.googleapis.com/maps/api/place
GEOCODING_API_KEY=your-geocoding-api-key-here
SERPAPI_API_KEY=your-serpapi-api-key-here
SERPAPI_BASE_URL=https://serpapi.com/search.json
SERPAPI_ENGINE=google

# =============================================================================
# Google Sheets & Drive Integration
# =============================================================================
GOOGLE_SERVICE_ACCOUNT_FILE=./credentials/service-account.json
GOOGLE_SHEETS_SCOPES=["https://www.googleapis.com/auth/spreadsheets","https://www.googleapis.com/auth/drive"]
GLOBAL_MAIL_TRACKING_SHEET_ID=1bGJotWtJT17Od34Ff62o7BArqEQgZOlgYI-bznDolZA

# =============================================================================
# PostgreSQL Database Configuration
# =============================================================================
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DATABASE=n8n_founderstories
POSTGRES_USERNAME=postgres
POSTGRES_PASSWORD=your-secure-password-here
POSTGRES_MIN_CONNECTIONS=5
POSTGRES_MAX_CONNECTIONS=20
POSTGRES_POOL_TIMEOUT=30
POSTGRES_SSL_MODE=require
POSTGRES_ECHO_SQL=false

# =============================================================================
# Database Operation Modes
# =============================================================================
ENABLE_POSTGRES=true
HYBRID_MODE=true
POSTGRES_PRIMARY=true

# =============================================================================
# Database Write Toggles
# =============================================================================
HUNTER_COMPANIES_DB_ENABLED=true
HUNTER_AUDIT_DB_ENABLED=true
GOOGLE_MAPS_RESULTS_DB_ENABLED=true
GOOGLE_MAPS_ENRICHED_DB_ENABLED=true
WEB_SEARCH_RESULTS_DB_ENABLED=true

# =============================================================================
# Database Batch Sizes
# =============================================================================
HUNTER_DB_BATCH_SIZE_RESULTS=200
HUNTER_DB_BATCH_SIZE_AUDIT=50
GOOGLE_MAPS_DB_BATCH_SIZE_RESULTS=200
GOOGLE_MAPS_DB_BATCH_SIZE_ENRICHED=100
WEB_SEARCH_DB_BATCH_SIZE_RESULTS=200

# =============================================================================
# Export Configuration
# =============================================================================
HUNTER_SHEETS_EXPORT_ENABLED=true
HUNTER_SHEETS_LIVE_APPEND_ENABLED=false
GOOGLE_MAPS_SHEETS_EXPORT_ENABLED=true
GOOGLE_MAPS_SHEETS_LIVE_APPEND_ENABLED=false
MASTER_SHEETS_EXPORT_ENABLED=true

# =============================================================================
# Web Scraper & Enrichment Configuration
# =============================================================================
DOMAIN_CONCURRENCY=4
CRAWL4AI_MAX_CONCURRENCY=3
LLM_MAX_CONCURRENCY=6
TOP_K_PAGES=4
CRAWL_TIMEOUT_S=40.0
WAIT_AFTER_LOAD_S=0.0
HEADLESS=true
USER_AGENT=Mozilla/5.0 (FounderStories LLM)
LANGUAGE=de
MAX_CHARS_PER_PAGE=18000

# =============================================================================
# Crawl4AI Advanced Configuration
# =============================================================================
CRAWL_GLOBAL_MAX_CONCURRENCY=20
CRAWL_DOMAIN_WORKERS=15
CRAWL4AI_PROFILE_DIR=./crawl4ai-profile
CRAWL4AI_TIMEOUT_S=12.0
CRAWL4AI_HEADLESS=true
CRAWL4AI_WAIT_AFTER_LOAD_S=0.0